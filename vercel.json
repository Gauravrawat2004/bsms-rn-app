{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/favicon.ico",
      "status": 204
    },
    {
      "src": "/favicon.png",
      "status": 204
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
